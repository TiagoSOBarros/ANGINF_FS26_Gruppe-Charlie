<html lang="de">
<head>
    <meta charset="UTF-8">
    <title>Wetter App</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.c
    loudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body {
            background: linear-gradient(135deg, #1e3a8a, #0f172a);
            font-family: system-ui, -apple-system, sans-serif;
            color: white;
        }

        .weather-card {
            background: rgba(255, 255, 255, 0.12);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.2);
        }
    </style>
</head>

<body class="flex items-center justify-center min-h-screen">

<div class="max-w-lg w-full mx-4">
    <div class="weather-card rounded-3xl p-10 shadow-2xl">

        <!-- Ort + Datum -->

        <div class="flex justify-between items-start mb-6">
            <div>
                <h1 id="ort" class="text-4xl font-bold">Lädt...</h1>
                <p id="datum" class="text-lg text-white/70">--</p>
            </div>
            <i id="icon" class="fas fa-cloud text-6xl text-yellow-300"></i>
        </div>

        <!-- Temperatur -->
        <div class="flex items-baseline gap-2 mb-8">
            <div id="temperatur" class="text-8xl font-light">--</div>
            <div class="text-4xl">°C</div>
        </div>

        <!-- Wetterart -->
        <p id="wetterart" class="text-3xl text-white/90 mb-8">--</p>

        <!-- Luftfeuchtigkeit -->
        <div class="flex items-center gap-4 bg-white/10 rounded-2xl p-6">
            <i class="fas fa-droplet text-4xl text-blue-300"></i>
            <div class="flex-1">
                <p class="text-sm uppercase tracking-widest text-white/60">Luftfeuchtigkeit</p>
                <div class="flex items-baseline gap-2">
                    <span id="luftfeuchtigkeit" class="text-5xl font-semibold">--</span>
                    <span class="text-3xl">%</span>
                </div>
            </div>
        </div>

        <p class="text-center text-xs text-white/40 mt-12">
            Open-Meteo API • Frontend
        </p>
    </div>
</div>

<script>
    // Zürich Koordinaten
    const LAT = 47.3769;
    const LON = 8.5417;

    function mapWeatherCode(code) {
        if (code === 0) return { text: "Sonnig", icon: "fa-sun" };
        if (code <= 3) return { text: "Bewölkt", icon: "fa-cloud-sun" };
        if (code <= 48) return { text: "Nebel", icon: "fa-smog" };
        if (code <= 67) return { text: "Regen", icon: "fa-cloud-rain" };
        if (code <= 77) return { text: "Schnee", icon: "fa-snowflake" };
        if (code <= 99) return { text: "Gewitter", icon: "fa-bolt" };
        return { text: "Unbekannt", icon: "fa-cloud" };
    }

    async function ladeWetter() {
        try {
            const url = `https://api.open-meteo.com/v1/forecast?latitude=${LAT}&longitude=${LON}&current_weather=true&hourly=relativehumidity_2m`;

            const res = await fetch(url);
            const data = await res.json();

            const current = data.current_weather;

            // aktuelle Stunde finden für Luftfeuchtigkeit
            const nowIndex = data.hourly.time.indexOf(current.time);
            const humidity = data.hourly.relativehumidity_2m[nowIndex];

            const weather = mapWeatherCode(current.weathercode);

            document.getElementById("ort").textContent = "Zürich";
            document.getElementById("datum").textContent = new Date().toLocaleString('de-CH');
            document.getElementById("temperatur").textContent = Math.round(current.temperature);
            document.getElementById("wetterart").textContent = weather.text;
            document.getElementById("luftfeuchtigkeit").textContent = humidity;

            const icon = document.getElementById("icon");
            icon.className = `fas ${weather.icon} text-6xl text-yellow-300`;

        } catch (e) {
            console.error(e);
            alert("Fehler beim Laden der Wetterdaten");
        }
    }

    // initial laden
    ladeWetter();

    // alle 10 Minuten aktualisieren
    setInterval(ladeWetter, 600000);
</script>

</body>
</html
